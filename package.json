{
  "name": "jstorm",
  "version": "0.18.0",
  "description": "JavaScript Storage ORM (Object-Relational Mapper) for LocalStorage and Chrome Storage API",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "test": "jest --config=./jest.config.ts",
    "test:all": "pnpm run test && pnpm run e2e",
    "build": "pnpm run build:lib && pnpm run build:e2e && pnpm run build:doc",
    "build:lib": "tsc -p ./tsconfig.json && cp README.md lib/ && node ./scripts/stage-manifest.js",
    "build:e2e": "parcel build --no-cache --target e2e",
    "build:doc": "parcel build --no-cache --target docs",
    "e2e": "pnpm run build:lib && pnpm run build:e2e && ts-node ./e2e/run.ts",
    "doc": "pnpm run build:lib && pnpm run build:doc && echo chrome.exe ./docs/index.html --user-data-dir=./docs/tmp --disable-web-security",
    "clean": "rm -rf ./lib ./e2e/app/dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/otiai10/jstorm.git"
  },
  "keywords": [
    "chrome",
    "storage",
    "object-relation-mapper",
    "orm"
  ],
  "author": "otiai10",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/otiai10/jstorm/issues"
  },
  "homepage": "https://github.com/otiai10/jstorm#readme",
  "publishConfig": {
    "directory": "lib"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.7.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.1",
    "jest": "^29.3.1",
    "parcel": "^2.8.2",
    "puppeteer": "^23.11.1",
    "ts-jest": "^29.0.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.4.3"
  },
  "targets": {
    "main": false,
    "e2e": {
      "source": "./e2e/app/src/background.js",
      "distDir": "./e2e/app/dist",
      "optimize": false,
      "sourceMap": false
    },
    "docs": {
      "source": "./docs/main.tsx",
      "distDir": "./docs",
      "optimize": true,
      "sourceMap": false
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "lmdb",
      "msgpackr-extract",
      "puppeteer"
    ]
  }
}
